# Admin password for write access
ADMIN_PASSWORD=changeme

# Secret for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=changeme

# Protects the cron cleanup endpoint
CRON_SECRET=changeme

# Vercel Postgres connection string (provided by Vercel when you create a Postgres store)
POSTGRES_URL=postgres://user:pass@host/db

# Vercel Blob read/write token (provided by Vercel when you create a Blob store)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
